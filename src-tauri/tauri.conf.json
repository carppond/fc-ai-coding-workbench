{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-schema/refs/heads/v2/schema.json",
  "productName": "拾光 AI 编程平台",
  "version": "0.1.0",
  "identifier": "com.shiguang.ai-coding",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "app": {
    "windows": [
      {
        "title": "拾光 AI 编程平台",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
